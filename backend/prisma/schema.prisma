generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           String    @id @default(uuid())
  name         String
  email        String    @unique
  password     String
  phone        String
  location     String
  coins        Int       @default(0)
  depositPaid  Boolean   @default(false) @map("deposit_paid")
  rating       Float     @default(0)
  createdAt    DateTime  @default(now()) @map("created_at")
  books        Book[]
  requestsMade Exchange[] @relation("Requester")
  booksOwned   Exchange[] @relation("Owner")
  transactions Transaction[]
  reviewsGiven Review[]  @relation("Reviewer")
  reviewsReceived Review[] @relation("Reviewee")

  @@map("users")
}

model Book {
  id           String    @id @default(uuid())
  title        String
  author       String
  genre        String
  mrp          Int
  coinValue    Int       @map("coin_value")
  condition    String
  images       String[]
  ownerId      String    @map("owner_id")
  location     String
  status       String    @default("Available")
  createdAt    DateTime  @default(now()) @map("created_at")

  owner        User      @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  exchanges    Exchange[]

  @@map("books")
}

model Exchange {
  id           String    @id @default(uuid())
  bookId       String    @map("book_id")
  ownerId      String    @map("owner_id")
  requesterId  String    @map("requester_id")
  status       String    @default("Requested")
  coinValue    Int       @map("coin_value")
  createdAt    DateTime  @default(now()) @map("created_at")

  book         Book      @relation(fields: [bookId], references: [id], onDelete: Cascade)
  owner        User      @relation("Owner", fields: [ownerId], references: [id], onDelete: Cascade)
  requester    User      @relation("Requester", fields: [requesterId], references: [id], onDelete: Cascade)
  transactions Transaction[]

  @@map("exchanges")
}

model Transaction {
  id           String    @id @default(uuid())
  userId       String    @map("user_id")
  coins        Int
  type         String    // Earned, Spent, Refund
  exchangeId   String?   @map("exchange_id")
  createdAt    DateTime  @default(now()) @map("created_at")

  user         User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  exchange     Exchange? @relation(fields: [exchangeId], references: [id], onDelete: SetNull)

  @@map("transactions")
}

model Review {
  id           String    @id @default(uuid())
  reviewerId   String    @map("reviewer_id")
  revieweeId   String    @map("reviewee_id")
  exchangeId   String    @map("exchange_id")
  rating       Int       // 1 to 5
  comment      String?
  createdAt    DateTime  @default(now()) @map("created_at")

  reviewer     User      @relation("Reviewer", fields: [reviewerId], references: [id], onDelete: Cascade)
  reviewee     User      @relation("Reviewee", fields: [revieweeId], references: [id], onDelete: Cascade)

  @@map("reviews")
}
