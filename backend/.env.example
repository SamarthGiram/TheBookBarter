# PostgreSQL connection string (e.g. from Supabase, Neon, Railway)
DATABASE_URL="postgresql://user:password@host:5432/thebookbarter?schema=public"

# JSON Web Token secret – use a long random string
JWT_SECRET="replace-with-a-strong-random-secret"

# Razorpay credentials
RAZORPAY_KEY_ID="rzp_test_XXXXXXXXXXXX"
RAZORPAY_KEY_SECRET="your_razorpay_secret"

# URL of the deployed frontend (used for CORS)
FRONTEND_URL="https://your-frontend.vercel.app"

# Server port (not required on Vercel / Netlify – managed automatically)
PORT=5000
