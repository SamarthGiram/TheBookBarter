{
  "version": 2,
  "builds": [
    {
      "src": "api/index.ts",
      "use": "@vercel/node"
    }
  ],
  "routes": [
    {
      "src": "/(.*)",
      "dest": "api/index.ts"
    }
  ],
  "env": {
    "DATABASE_URL":          "@database_url",
    "JWT_SECRET":            "@jwt_secret",
    "RAZORPAY_KEY_ID":       "@razorpay_key_id",
    "RAZORPAY_KEY_SECRET":   "@razorpay_key_secret",
    "FRONTEND_URL":          "@frontend_url"
  }
}
